{
  "framework": "vite",
  "buildCommand": "cd artifacts/solaraforge-web && pnpm run build",
  "installCommand": "pnpm install",
  "outputDirectory": "artifacts/solaraforge-web/dist/public",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
