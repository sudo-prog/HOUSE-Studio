{
  "framework": "vite",
  "buildCommand": "cd artifacts/solaraforge-web && pnpm run build",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "rootDirectory": "../..",
  "devCommand": "cd artifacts/solaraforge-web && pnpm run dev",
  "env": [
    {
      "key": "VITE_API_BASE_URL",
      "value": "https://<your-api-server>.com"
    }
  ]
}
