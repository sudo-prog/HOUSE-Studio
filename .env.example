# SolaraForge environment variables
# Copy to .env and fill in real values. .env is git-ignored.

# --- Web frontend (Vite) ---
# Base URL of the deployed API server. Empty string => same-origin (API served by host).
VITE_API_BASE_URL=

# --- API server (Express + Drizzle) ---
# PostgreSQL connection string (required for DB-backed routes).
DATABASE_URL=postgresql://user:password@localhost:5432/solaraforge

# OpenAI key for AI chat / moodboard analysis.
OPENAI_API_KEY=

# Port the API server listens on.
PORT=3000
